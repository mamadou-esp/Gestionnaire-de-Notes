<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_outline"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Rechercher"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#828282"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnFavoris"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_rounded_outline"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Favoris"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/btnTri"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_rounded_outline"
            android:gravity="center"
            android:text="⇅"
            android:textColor="#000000"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyNotes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aucune notes"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="normal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNotes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"
        tools:listitem="@layout/item_note" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPaletteContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeColor="#828282"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="6dp">

            <View
                android:id="@+id/viewColorGreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_green" />

            <View
                android:id="@+id/viewColorRed"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_red" />

            <View
                android:id="@+id/viewColorBlue"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_blue" />

            <View
                android:id="@+id/viewColorYellow"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_yellow" />

            <View
                android:id="@+id/viewColorOrange"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_orange" />

            <View
                android:id="@+id/viewColorGray"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_margin="6dp"
                android:background="@drawable/circle_gray" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabClosePalette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="Fermer la palette"
                android:src="@android:drawable/ic_input_add"
                app:backgroundTint="#000000"
                app:fabSize="mini"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Ouvrir la palette"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#000000"
        app:fabSize="normal"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>